# ----- IntelliLeads / scraper backend configuration -----
# Copy to ".env" and fill in the keys for the providers you want to use.

# Port the scraper API listens on (frontend dev server proxies /api here).
SCRAPER_PORT=4000

# --- Licensed data providers (recommended, reliable) ---
# Apollo.io organization search API key (paid plan required).
APOLLO_API_KEY=

# Explorium ("Vibe Prospecting") business data API key.
EXPLORIUM_API_KEY=
# Optional override if your Explorium plan uses a different base URL.
# EXPLORIUM_API_BASE=https://api.explorium.ai/v1

# --- D&B scraper ---
# dnb.com blocks plain datacenter requests (HTTP 403). To make the scraper work
# you must route through a rendering / anti-bot gateway. Provide a template URL
# containing {url} (the target is URL-encoded and substituted in).
#
# ScraperAPI (recommended). D&B is a hard target, so enable JS rendering and
# premium proxies. Replace YOUR_KEY with your ScraperAPI dashboard key:
#   DNB_SCRAPER_GATEWAY=https://api.scraperapi.com/?api_key=YOUR_KEY&render=true&premium=true&url={url}
#
# If results are still blocked/empty, upgrade premium=true to ultra_premium=true.
#
# ScrapingBee alternative:
#   DNB_SCRAPER_GATEWAY=https://app.scrapingbee.com/api/v1/?api_key=YOUR_KEY&render_js=true&url={url}
DNB_SCRAPER_GATEWAY=
# Optional custom User-Agent for direct (non-gateway) requests.
# DNB_USER_AGENT=
